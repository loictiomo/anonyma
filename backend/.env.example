PORT=5000

# Connection string PostgreSQL — fournie automatiquement par Render
# si tu utilises le render.yaml (base "anonyma-db"). En local, pointe
# vers ta base de dev.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Secret utilisé pour signer les JWT — générer une valeur forte et unique en prod
# (Render peut le générer automatiquement via render.yaml)
JWT_SECRET=change_me_in_production

# URLs frontend autorisées en CORS, séparées par des virgules
# Ex: https://anonyma-xxxx.vercel.app,https://www.mondomaine.com
ALLOWED_ORIGINS=
